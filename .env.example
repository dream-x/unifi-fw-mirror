# copy to .env -- it is gitignored, unlike this file

# SOCKS5 proxy for downloads. Leave unset for a direct connection; set it if the
# CDN answers 451 while the API keeps working.
# UNIFI_FW_PROXY=user:password@proxy.example.net:1080

# seconds between syncs; 0 syncs once and exits
SYNC_INTERVAL=2592000

# host port the mirror is served on
HTTP_PORT=8080
